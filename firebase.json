{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "!**/*.@(ts|tsx|js|json|png|jpg|jpeg|gif|svg|css|html)",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(ts|tsx)",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/javascript"
          }
        ]
      }
    ]
  }
}